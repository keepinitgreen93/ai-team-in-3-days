# ============================================
# Your AI Employee's Connections
# ============================================
# Fill these in as you connect tools.
# You don't need all of these right away —
# just add them when you're ready.
# ============================================

# --- Anthropic (Required for Claude Code) ---
# Your Claude API key (if using API directly)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Database (Supabase) ---
# Get these from: supabase.com > Project > Settings > API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Hosting (Vercel) ---
# Get this from: vercel.com > Settings > Tokens
# VERCEL_TOKEN=your-vercel-token

# --- Email ---
# SMTP or API credentials for sending emails
# EMAIL_API_KEY=your-email-api-key

# --- CRM ---
# Your CRM API key (HubSpot, GoHighLevel, etc.)
# CRM_API_KEY=your-crm-api-key

# --- Social Media ---
# API keys for social platforms if needed
# INSTAGRAM_ACCESS_TOKEN=your-token
# TWITTER_API_KEY=your-key

# --- Other Tools ---
# Add any other API keys your employee needs
# TOOL_NAME_API_KEY=your-key
